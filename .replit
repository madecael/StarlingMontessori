modules = ["nodejs-20"]
run = "npm run dev -- --host 0.0.0.0 --port 3000"
hidden = [".astro", "dist", "node_modules", ".vscode"]

[nix]
channel = "stable-24_05"

[env]
HOST = "0.0.0.0"
PORT = "3000"

[deployment]
deploymentTarget = "cloudrun"
build = ["npm", "ci", "&&", "npm", "run", "build"]
run = ["npm", "start"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 4321
externalPort = 3000
