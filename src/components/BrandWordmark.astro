---
interface Props {
  size?: "sm" | "md" | "lg";
  /** Kept for backwards-compat; the PNG already includes the "Montessori School" subline. */
  withSubline?: boolean;
}
const { size = "md" } = Astro.props;
const heightClass = size === "lg" ? "h-16" : size === "sm" ? "h-9" : "h-12";
---
<img
  src="/images/starling-logo.png"
  alt="Starling Montessori School"
  class={`${heightClass} w-auto block`}
/>
