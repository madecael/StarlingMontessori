---
interface Row { label: string; values: string[]; }
interface Props { eyebrow: string; title: string; columns: string[]; rows: Row[]; footnote?: string; }
const { eyebrow, title, columns, rows, footnote } = Astro.props;
const totalCols = columns.length + 1;
---
<section class="px-8 lg:px-12 py-16 max-w-[1240px] mx-auto">
  <div class="eyebrow">{eyebrow}</div>
  <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 mb-6 tracking-tightest">{title}</h2>
  <div class="bg-white rounded-3xl overflow-hidden border border-cetacean/10">
    <div class="grid text-[13px]" style={`grid-template-columns: 1.4fr ${columns.map(() => "1fr").join(" ")};`}>
      <div class="p-4 bg-seashell-shade font-semibold"></div>
      {columns.map((col, i) => (
        <div class={`p-4 font-semibold ${i === columns.length - 1 ? "bg-cetacean text-seashell" : "bg-seashell-shade text-cetacean"}`}>{col}</div>
      ))}
      {rows.map((row) => (
        <>
          <div class="p-4 text-cetacean-70 border-t border-cetacean/5">{row.label}</div>
          {row.values.map((v, i) => (
            <div class={`p-4 border-t border-cetacean/5 ${i === row.values.length - 1 ? "bg-cetacean text-seashell" : "text-cetacean"}`}>
              {v.startsWith("★") ? <span><span class="text-pearly-light">★</span> {v.slice(1).trim()}</span> : v}
            </div>
          ))}
        </>
      ))}
    </div>
  </div>
  {footnote && <p class="text-xs text-cetacean-70 mt-2.5">{footnote}</p>}
</section>
