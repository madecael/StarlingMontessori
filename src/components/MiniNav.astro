---
import BirdMark from "./BirdMark.astro";
import BrandWordmark from "./BrandWordmark.astro";
import { getEntry } from "astro:content";
interface Props {
  ctaLabel: string;
  ctaHref?: string;
}
const { ctaLabel, ctaHref = "#tour" } = Astro.props;
const settings = await getEntry("settings", "site");
const phone = settings?.data.phone;
---
<header class="flex items-center justify-between px-8 py-3.5 border-b border-cetacean/10 bg-seashell/85 backdrop-blur sticky top-0 z-10">
  <div class="flex items-center gap-2.5">
    <BirdMark size={24} />
    <BrandWordmark size="md" withSubline />
  </div>
  <div class="flex items-center gap-3.5 text-sm text-cetacean">
    <a href={`tel:${phone?.replace(/[^0-9+]/g, "")}`} class="hidden sm:inline" data-event="phone_click">📞 {phone}</a>
    <a href={ctaHref} class="btn btn-primary text-[13px] px-4 py-2">{ctaLabel}</a>
  </div>
</header>
