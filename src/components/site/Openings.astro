---
type Qualification = string | { label: string; href?: string };
interface Position {
  title: string;
  type: string;
  startDate?: string;
  summary: string;
  qualifications: Qualification[];
}
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  fallbackTitle?: string;
  fallbackBody?: string;
  positions: Position[];
}
const { eyebrow, title, intro, fallbackTitle, fallbackBody, positions } = Astro.props;
---
<section class="px-6 lg:px-8 py-16 max-w-[1240px] mx-auto">
  {eyebrow && <div class="eyebrow">{eyebrow}</div>}
  {title && <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 mb-3 tracking-tightest">{title}</h2>}
  {intro && <p class="text-base text-cetacean-70 mb-7 max-w-2xl leading-relaxed">{intro}</p>}
  {positions.length > 0 ? (
    <div class="grid gap-4 md:grid-cols-2">
      {positions.map((p) => (
        <article class="bg-white rounded-3xl p-7 flex flex-col gap-3 shadow-sm">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <h3 class="text-2xl font-light text-cetacean tracking-tightest leading-tight">{p.title}</h3>
            <span class="text-[11px] uppercase tracking-eyebrow font-semibold text-pearly-deep bg-seashell-shade px-3 py-1 rounded-pill whitespace-nowrap">{p.type}</span>
          </div>
          {p.startDate && <div class="text-sm text-cetacean-70">Starts {p.startDate}</div>}
          <p class="text-sm text-cetacean-70 leading-relaxed">{p.summary}</p>
          {p.qualifications.length > 0 && (
            <ul class="grid gap-1.5 text-sm text-cetacean mt-1">
              {p.qualifications.map((q) => {
                if (typeof q === "string") return <li>· {q}</li>;
                return q.href
                  ? <li>· <a href={q.href} target="_blank" rel="noopener" class="underline decoration-pearly-deep/40 underline-offset-2 hover:decoration-pearly-deep">{q.label}</a></li>
                  : <li>· {q.label}</li>;
              })}
            </ul>
          )}
        </article>
      ))}
    </div>
  ) : (
    <div class="bg-white rounded-3xl p-8 max-w-2xl">
      <h3 class="text-xl font-light text-cetacean mb-2 tracking-tightest">{fallbackTitle ?? "We're not actively hiring right now."}</h3>
      <p class="text-sm text-cetacean-70 leading-relaxed">{fallbackBody ?? "If Starling resonates with you, we'd love to keep your name on file. Send us a note — we hire seasonally and stay in touch with people whose values align with ours."}</p>
    </div>
  )}
</section>
