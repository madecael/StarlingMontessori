---
interface Props { eyebrow: string; title: string; categories: { name: string; examples: string[] }[]; }
const { eyebrow, title, categories } = Astro.props;
---
<section class="px-6 lg:px-8 py-16 max-w-[1240px] mx-auto">
  <div class="eyebrow">{eyebrow}</div>
  <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 mb-8 tracking-tightest">{title}</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
    {categories.map((c) => (
      <div class="bg-white rounded-2xl p-6">
        <h3 class="text-lg font-light text-cetacean">{c.name}</h3>
        <ul class="mt-3 flex flex-col gap-1.5 text-sm text-cetacean-70">
          {c.examples.map((e) => <li>· {e}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>
