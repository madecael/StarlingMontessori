---
interface Quote { quote: string; attribution: string; }
interface Props { eyebrow?: string; title?: string; quotes: Quote[]; }
const { eyebrow, title, quotes } = Astro.props;
const isSingle = quotes.length === 1;
---
<section class="px-6 lg:px-8 py-16 max-w-[1240px] mx-auto">
  {(eyebrow || title) && (
    <div class="mb-10 text-center">
      {eyebrow && <div class="eyebrow">{eyebrow}</div>}
      {title && <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 tracking-tightest">{title}</h2>}
    </div>
  )}
  <div class={isSingle ? "max-w-2xl mx-auto" : "grid md:grid-cols-2 lg:grid-cols-3 gap-5"}>
    {quotes.map((q) => (
      <figure class={`bg-white rounded-3xl p-7 ${isSingle ? "text-center" : ""}`}>
        <blockquote class={`font-display italic text-xl lg:text-[22px] text-cetacean leading-snug tracking-tightest`}>
          &ldquo;{q.quote}&rdquo;
        </blockquote>
        <figcaption class="text-[11px] uppercase tracking-eyebrow font-semibold text-cetacean-70 mt-5">— {q.attribution}</figcaption>
      </figure>
    ))}
  </div>
</section>
