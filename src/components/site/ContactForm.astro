---
import { getEntry } from "astro:content";
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}
const { eyebrow = "GET IN TOUCH", title = "Send us a message.", subtitle = "Fabienne or someone from our team will respond within one business day." } = Astro.props;
---
<section id="contact-form" class="px-6 lg:px-8 py-12 max-w-[760px] mx-auto">
  <div class="eyebrow">{eyebrow}</div>
  <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 mb-3 tracking-tightest">{title}</h2>
  <p class="text-base text-cetacean-70 leading-relaxed mb-7">{subtitle}</p>
  <form id="contact-form-el" method="POST" action="/api/contact-request" class="bg-white rounded-3xl p-7 shadow-sm" novalidate>
    <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <label class="block">
        <span class="text-[11px] tracking-eyebrow font-semibold mb-1.5 block">YOUR NAME</span>
        <input required name="name" type="text" class="w-full px-3 py-2.5 rounded-xl border border-cetacean/20 bg-white text-sm" />
      </label>
      <label class="block">
        <span class="text-[11px] tracking-eyebrow font-semibold mb-1.5 block">EMAIL</span>
        <input required name="email" type="email" class="w-full px-3 py-2.5 rounded-xl border border-cetacean/20 bg-white text-sm" />
      </label>
      <label class="block sm:col-span-2">
        <span class="text-[11px] tracking-eyebrow font-semibold mb-1.5 block">SUBJECT</span>
        <input name="subject" type="text" class="w-full px-3 py-2.5 rounded-xl border border-cetacean/20 bg-white text-sm" />
      </label>
      <label class="block sm:col-span-2">
        <span class="text-[11px] tracking-eyebrow font-semibold mb-1.5 block">MESSAGE</span>
        <textarea required name="message" rows="5" class="w-full px-3 py-2.5 rounded-xl border border-cetacean/20 bg-white text-sm leading-relaxed"></textarea>
      </label>
    </div>
    <div class="mt-4 flex justify-between items-center flex-wrap gap-3">
      <button type="submit" class="btn btn-pearly text-sm font-medium">Send message</button>
    </div>
    <p data-form-status class="text-sm mt-3 hidden"></p>
  </form>
</section>
<script>
  const form = document.getElementById("contact-form-el") as HTMLFormElement | null;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const status = form.querySelector("[data-form-status]") as HTMLElement;
      status.classList.remove("hidden");
      status.textContent = "Sending…";
      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/contact-request", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error("submit failed");
        form.reset();
        window.location.assign("/confirmation-contact");
      } catch (err) {
        status.textContent = "Something went wrong. Please email info@starlingmontessorischool.com.";
        status.style.color = "#8B5C7E";
      }
    });
  }
</script>
