---
import { getEntry } from "astro:content";
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  fallbackTitle?: string;
  fallbackBody?: string;
}
const { eyebrow, title, intro, fallbackTitle, fallbackBody } = Astro.props;
const settings = await getEntry("settings", "site");
const url = settings?.data.bookingUrl;
---
<section class="px-6 lg:px-8 py-16 max-w-[1240px] mx-auto">
  {eyebrow && <div class="eyebrow">{eyebrow}</div>}
  {title && <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 mb-3 tracking-tightest">{title}</h2>}
  {intro && <p class="text-base text-cetacean-70 mb-7 max-w-2xl leading-relaxed">{intro}</p>}
  {url ? (
    <div class="bg-white rounded-3xl p-10 lg:p-14 shadow-sm grid lg:grid-cols-[1.3fr_1fr] gap-8 items-center">
      <div>
        <div class="text-[11px] uppercase tracking-eyebrow font-semibold text-pearly-deep">BOOK A TOUR</div>
        <h3 class="text-2xl lg:text-[28px] font-light text-cetacean mt-2 tracking-tightest leading-tight">
          Pick a time that works for your family.
        </h3>
        <p class="text-sm text-cetacean-70 mt-3 leading-relaxed max-w-md">
          30-minute tour with Fabienne, in person at the Toddler classroom on Capitol Hill. Saint Mark Episcopal (Primary) tours are by virtual walkthrough until the build-out completes.
        </p>
        <p class="text-sm text-cetacean-70 mt-2 leading-relaxed max-w-md">
          Booking is handled directly in Fabienne's Google Calendar — choose a slot, confirm, and you'll get an email confirmation right away.
        </p>
      </div>
      <div class="flex flex-col gap-3 items-stretch">
        <a
          href={url}
          target="_blank"
          rel="noopener"
          class="btn btn-pearly text-base justify-center py-4"
          data-event="booking_open_in_tab"
        >
          Open booking calendar →
        </a>
        <p class="text-xs text-cetacean-70 text-center">Opens in a new tab.</p>
      </div>
    </div>
  ) : (
    <div class="bg-white rounded-3xl p-8 text-cetacean-70">
      <div class="text-lg font-light text-cetacean mb-2">{fallbackTitle ?? "Booking opens soon."}</div>
      <p class="text-sm leading-relaxed">{fallbackBody ?? "Tour scheduling is being set up. In the meantime, please email info@starlingmontessorischool.com or fill in the contact form."}</p>
    </div>
  )}
</section>
