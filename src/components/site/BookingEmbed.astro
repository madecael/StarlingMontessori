---
import { getEntry } from "astro:content";
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  fallbackTitle?: string;
  fallbackBody?: string;
}
const { eyebrow, title, intro, fallbackTitle, fallbackBody } = Astro.props;
const settings = await getEntry("settings", "site");
const toddlerUrl = settings?.data.bookingUrlToddler;
const primaryUrl = settings?.data.bookingUrlPrimary;
const hasAnyUrl = !!(toddlerUrl || primaryUrl);
---
<section class="px-6 lg:px-8 py-16 max-w-[1240px] mx-auto">
  {eyebrow && <div class="eyebrow">{eyebrow}</div>}
  {title && <h2 class="text-3xl lg:text-4xl font-light text-cetacean mt-2 mb-3 tracking-tightest">{title}</h2>}
  {intro && <p class="text-base text-cetacean-70 mb-7 max-w-2xl leading-relaxed">{intro}</p>}
  {hasAnyUrl ? (
    <div class="grid gap-5 md:grid-cols-2">
      {toddlerUrl && (
        <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-sm flex flex-col">
          <div class="text-[11px] uppercase tracking-eyebrow font-semibold text-pearly-deep">TODDLER PROGRAM</div>
          <h3 class="text-2xl font-light text-cetacean mt-2 tracking-tightest leading-tight">
            16 months – 3 years
          </h3>
          <p class="text-sm text-cetacean-70 mt-3 leading-relaxed flex-1">
            30-minute in-person tour with Fabienne at our Toddler classroom on Capitol Hill. See the work cycle in motion and meet the team.
          </p>
          <a
            href={toddlerUrl}
            target="_blank"
            rel="noopener"
            class="btn btn-pearly mt-6 justify-center"
            data-event="booking_open_in_tab"
          >
            Schedule Toddler tour →
          </a>
        </div>
      )}
      {primaryUrl && (
        <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-sm flex flex-col">
          <div class="text-[11px] uppercase tracking-eyebrow font-semibold text-pearly-deep">PRIMARY PROGRAM</div>
          <h3 class="text-2xl font-light text-cetacean mt-2 tracking-tightest leading-tight">
            3 – 6 years · Opening Aug 2026
          </h3>
          <p class="text-sm text-cetacean-70 mt-3 leading-relaxed flex-1">
            30-minute tour for prospective Primary families. Toddler classroom visit plus Saint Mark Episcopal walkthrough. Virtual option for relocating families.
          </p>
          <a
            href={primaryUrl}
            target="_blank"
            rel="noopener"
            class="btn btn-outline mt-6 justify-center"
            data-event="booking_open_in_tab"
          >
            Schedule Primary tour →
          </a>
        </div>
      )}
    </div>
  ) : (
    <div class="bg-white rounded-3xl p-8 text-cetacean-70">
      <div class="text-lg font-light text-cetacean mb-2">{fallbackTitle ?? "Booking opens soon."}</div>
      <p class="text-sm leading-relaxed">{fallbackBody ?? "Tour scheduling is being set up. In the meantime, please email info@starlingmontessorischool.com or fill in the contact form."}</p>
    </div>
  )}
</section>
