---
import SiteLayout from "../layouts/SiteLayout.astro";
import { conversionScript } from "../lib/conversions";

const fireScript = conversionScript("contactFormSubmit");
---
<SiteLayout title="Thank you — your message is in" description="Your message was received. We'll respond within one business day." noindex>
  <section class="px-6 lg:px-8 py-24 lg:py-32 max-w-[760px] mx-auto text-center">
    <div class="eyebrow">MESSAGE RECEIVED</div>
    <h1 class="text-4xl lg:text-5xl font-light text-cetacean mt-4 mb-6 tracking-tightest leading-tight">
      Thank you. We've received your message.
    </h1>
    <p class="text-lg text-cetacean-70 leading-relaxed max-w-xl mx-auto">
      Fabienne or someone from our team will respond within one business day.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-10">
      <a href="/" class="btn btn-pearly">Back to home</a>
      <a href="/open-house" class="btn btn-outline">Schedule a tour</a>
    </div>
  </section>
  <script set:html={fireScript}></script>
</SiteLayout>
