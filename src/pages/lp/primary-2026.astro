---
import { getEntry } from "astro:content";
import LPLayout from "../../layouts/LPLayout.astro";
import ObjectionHero from "../../components/lp/ObjectionHero.astro";
import BlockRenderer from "../../components/lp/BlockRenderer.astro";

const lp = await getEntry("landing", "primary-2026");
if (!lp) throw new Error("LP content missing");
const d = lp.data;
---
<LPLayout title={d.title} description={d.description} ctaLabel="Reserve a tour" locationLine="Saint Mark Episcopal Church, Capitol Hill, Washington DC">
  <ObjectionHero
    eyebrow={d.eyebrow}
    headline={d.heroHeadline}
    headlineHighlight={d.heroHeadlineHighlight}
    subhead={d.heroSubhead}
    photo={d.heroPhoto}
    alt={d.heroAlt}
    location={d.heroLocation}
    ctas={d.heroCTAs}
    scarcity={{ opens: "Aug 2026", seats: "12 total" }}
  />
  {d.blocks.map((b) => <BlockRenderer block={b} />)}
</LPLayout>
