---
import SiteLayout from "../layouts/SiteLayout.astro";
---
<SiteLayout title="Page not found · Starling Montessori" description="The page you're looking for has wandered off." noindex>
  <section class="px-6 lg:px-8 py-24 lg:py-32 max-w-[860px] mx-auto text-center">
    <div class="eyebrow">404</div>
    <h1 class="text-4xl lg:text-5xl font-light text-cetacean mt-4 mb-6 tracking-tightest leading-tight">
      The page you're looking for has wandered off.
    </h1>
    <p class="text-lg text-cetacean-70 leading-relaxed max-w-xl mx-auto">
      Let's find your way home. Below are a few places parents usually look for first.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/" class="btn btn-primary">Home</a>
      <a href="/programs/toddler" class="btn btn-outline">Toddler Community</a>
      <a href="/programs/primary" class="btn btn-outline">Primary Classroom</a>
      <a href="/open-house" class="btn btn-pearly">Schedule a tour</a>
    </div>
    <div class="mt-12 pt-8 border-t border-cetacean/10 text-sm text-cetacean-70 max-w-md mx-auto">
      Looking for something specific? Email us at <a href="mailto:info@starlingmontessorischool.com" class="underline">info@starlingmontessorischool.com</a>.
    </div>
  </section>
</SiteLayout>
