---
import SiteLayout from "../layouts/SiteLayout.astro";
---
<SiteLayout title="Thank you — your application is in" description="Your application was received. Fabienne will review it personally." noindex>
  <section class="px-6 lg:px-8 py-24 lg:py-32 max-w-[760px] mx-auto text-center">
    <div class="eyebrow">APPLICATION RECEIVED</div>
    <h1 class="text-4xl lg:text-5xl font-light text-cetacean mt-4 mb-6 tracking-tightest leading-tight">
      Thank you. Your application is in.
    </h1>
    <p class="text-lg text-cetacean-70 leading-relaxed max-w-xl mx-auto">
      Fabienne reviews every application personally. We respond to candidates whose background fits a current or upcoming role — typically within one to two weeks.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-10">
      <a href="/" class="btn btn-pearly">Back to home</a>
      <a href="/about" class="btn btn-outline">About Starling</a>
    </div>
  </section>
  <script>
    (function(){function fire(){if(typeof (window as any).gtag!=='function'){return setTimeout(fire,200);}(window as any).gtag('event','career_application_submit',{event_category:'form'});}fire();})();
  </script>
</SiteLayout>
