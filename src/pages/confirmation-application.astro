---
import SiteLayout from "../layouts/SiteLayout.astro";
import { conversionScript } from "../lib/conversions";

const fireScript = conversionScript("applicationSubmit");
---
<SiteLayout title="Thank you — your application is in" description="Your Starling Montessori application was received. Fabienne will review and reach out within a few business days." noindex>
  <section class="px-6 lg:px-8 py-24 lg:py-32 max-w-[760px] mx-auto text-center">
    <div class="eyebrow">APPLICATION RECEIVED</div>
    <h1 class="text-4xl lg:text-5xl font-light text-cetacean mt-4 mb-6 tracking-tightest leading-tight">
      Thank you. Your application is with us.
    </h1>
    <p class="text-lg text-cetacean-70 leading-relaxed max-w-xl mx-auto">
      Fabienne will review your application personally and reach out within a few business days. You're now on our waitlist for your child's program.
    </p>
    <p class="text-base text-cetacean-70 leading-relaxed max-w-xl mx-auto mt-4">
      In the meantime, if you haven't already toured the classroom, we'd love to welcome you in person.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-10">
      <a href="/open-house" class="btn btn-pearly" data-booking-trigger>Schedule a tour</a>
      <a href="/programs/toddler" class="btn btn-outline">Toddler Community</a>
      <a href="/programs/primary" class="btn btn-outline">Primary Classroom</a>
      <a href="/" class="btn btn-ghost">Home</a>
    </div>
  </section>
  <script set:html={fireScript}></script>
</SiteLayout>
