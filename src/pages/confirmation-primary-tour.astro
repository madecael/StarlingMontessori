---
import { getEntry } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { conversionScript } from "../lib/conversions";

const settings = (await getEntry("settings", "site"))!.data;
const fireScript = conversionScript("tourBookingPrimary", settings);
---
<SiteLayout title="Thank you — your Primary tour request is in" description="Your Primary classroom tour request was received. Fabienne will reach out within one business day." noindex>
  <section class="px-6 lg:px-8 py-24 lg:py-32 max-w-[760px] mx-auto text-center">
    <div class="eyebrow">RESERVATION REQUEST RECEIVED</div>
    <h1 class="text-4xl lg:text-5xl font-light text-cetacean mt-4 mb-6 tracking-tightest leading-tight">
      Thank you. We're holding a moment for your family.
    </h1>
    <p class="text-lg text-cetacean-70 leading-relaxed max-w-xl mx-auto">
      Fabienne will reach out within one business day to confirm a tour — in person at our existing Toddler classroom plus a walkthrough of Saint Mark Episcopal, or virtual if you're relocating.
    </p>
    <p class="text-base text-cetacean-70 leading-relaxed max-w-xl mx-auto mt-4">
      Twelve seats are available in the inaugural Primary class for August 2026.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-10">
      <a href="/open-house" class="btn btn-pearly" data-booking-trigger>Pick a time directly</a>
      <a href="/programs/primary" class="btn btn-outline">Read about Primary</a>
      <a href="/" class="btn btn-ghost">Home</a>
    </div>
  </section>
  <script set:html={fireScript}></script>
</SiteLayout>
