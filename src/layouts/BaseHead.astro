---
import "../styles/global.css";
import { getEntry } from "astro:content";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
}
const {
  title,
  description,
  noindex = false,
  image,
  imageAlt,
  type = "website",
} = Astro.props;
const settings = await getEntry("settings", "site");
const ga4 = settings?.data.ga4Id;
const adsId = settings?.data.googleAdsConversionId;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const defaultOG = "/images/photos/photo-classroom-1.png";
const ogPath = image ?? defaultOG;
const ogImageAbsolute = ogPath.startsWith("http")
  ? ogPath
  : new URL(ogPath, Astro.site).toString();
---
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  {noindex && <meta name="robots" content="noindex" />}
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:alt" content={imageAlt ?? "Starling Montessori School — Capitol Hill, Washington D.C."} />
  <meta property="og:site_name" content="Starling Montessori School" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {ga4 && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}></script>
      <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4}');${adsId ? `gtag('config','${adsId}');` : ""}`}></script>
    </>
  )}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Preschool",
    name: "Starling Montessori School",
    description: "Family-run AMI Montessori childcare center on Capitol Hill, Washington D.C. Toddler Community (ages 14–28 months) and Primary Classroom (ages 3–6, opening August 2026).",
    url: Astro.site?.toString(),
    telephone: settings?.data.phone,
    email: settings?.data.email,
    address: {
      "@type": "PostalAddress",
      streetAddress: settings?.data.address.line1,
      addressLocality: settings?.data.address.city,
      addressRegion: settings?.data.address.state,
      postalCode: settings?.data.address.zip,
      addressCountry: "US",
    },
    areaServed: { "@type": "Place", name: "Capitol Hill, Washington D.C." },
    founder: {
      "@type": "Person",
      name: "Fabienne Deaton",
      jobTitle: "Founder & Lead Guide",
      description: "AMI Diploma in Assistants to Infancy (0–3) and AMI Diploma in Primary (3–6). M.Ed., M.A.",
    },
    hasCredential: [
      { "@type": "EducationalOccupationalCredential", credentialCategory: "AMI", name: "Association Montessori Internationale (AMI) authentic" },
    ],
    educationalProgramMode: "onsite",
    audience: { "@type": "EducationalAudience", educationalRole: "Parents of children ages 14 months to 6 years" },
  })} />
</head>
