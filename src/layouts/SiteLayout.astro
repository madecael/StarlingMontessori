---
import BaseHead from "./BaseHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BookingModal from "../components/BookingModal.astro";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}
const { title, description, noindex } = Astro.props;
const currentPath = Astro.url.pathname;
---
<html lang="en">
  <BaseHead title={title} description={description} noindex={noindex} />
  <body class="bg-seashell text-cetacean">
    <SiteHeader currentPath={currentPath} />
    <main><slot /></main>
    <SiteFooter />
    <BookingModal />
    <script>
      document.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest("[data-event]");
        if (!target) return;
        const event = target.getAttribute("data-event");
        if (event && typeof (window as any).gtag === "function") {
          (window as any).gtag("event", event);
        }
      });
    </script>
  </body>
</html>
